    <script>
        document.addEventListener('DOMContentLoaded', function() {
            createFloatingStars();
            addFamilyCardAnimations();
            addSmoothScroll();
            initMusicControl();
        });

        function createFloatingStars() {
            const starsContainer = document.querySelector('.stars');
            
            for (let i = 0; i < 50; i++) {
                const star = document.createElement('div');
                star.className = 'star';
                star.style.position = 'absolute';
                star.style.width = Math.random() * 3 + 'px';
                star.style.height = star.style.width;
                star.style.background = '#FFD700';
                star.style.borderRadius = '50%';
                star.style.left = Math.random() * 100 + '%';
                star.style.top = Math.random() * 100 + '%';
                star.style.opacity = Math.random() * 0.7 + 0.3;
                star.style.animation = `twinkle ${Math.random() * 3 + 2}s infinite`;
                starsContainer.appendChild(star);
            }
        }

        function addFamilyCardAnimations() {
            const familyCards = document.querySelectorAll('.family-card');
            familyCards.forEach(card => {
                card.addEventListener('click', function() {
                    this.style.animation = 'none';
                    setTimeout(() => {
                        this.style.animation = '';
                    }, 10);
                });
            });
        }

        function addSmoothScroll() {
            document.documentElement.style.scrollBehavior = 'smooth';
        }

        function initMusicControl() {
            const musicToggle = document.getElementById('musicToggle');
            
            musicToggle.addEventListener('click', function() {
                musicToggle.classList.toggle('playing');
                if (musicToggle.classList.contains('playing')) {
                    musicToggle.setAttribute('title', 'Matikan Musik');
                } else {
                    musicToggle.setAttribute('title', 'Nyalakan Musik');
                }
            });
        }

        window.addEventListener('load', function() {
            setTimeout(() => {
                createConfetti();
            }, 800);
        });

        function createConfetti() {
            const confettiPieces = 60;
            const colors = ['#FFD700', '#D4AF37', '#1B7B4F', '#8B4513', '#FFA500', '#E8D5B7'];
            
            for (let i = 0; i < confettiPieces; i++) {
                const confetti = document.createElement('div');
                confetti.style.position = 'fixed';
                confetti.style.width = Math.random() * 10 + 5 + 'px';
                confetti.style.height = confetti.style.width;
                confetti.style.background = colors[Math.floor(Math.random() * colors.length)];
                confetti.style.left = Math.random() * 100 + '%';
                confetti.style.top = '-10px';
                confetti.style.opacity = '0.8';
                confetti.style.pointerEvents = 'none';
                confetti.style.zIndex = '999';
                confetti.style.borderRadius = '50%';
                
                document.body.appendChild(confetti);
                
                const duration = Math.random() * 3 + 2;
                const xOffset = (Math.random() - 0.5) * 200;
                const rotation = Math.random() * 360;
                
                confetti.animate([
                    { 
                        transform: `translateY(0) translateX(0) rotate(0deg)`, 
                        opacity: 0.8 
                    },
                    { 
                        transform: `translateY(${window.innerHeight + 50}px) translateX(${xOffset}px) rotate(${rotation}deg)`, 
                        opacity: 0 
                    }
                ], {
                    duration: duration * 1000,
                    easing: 'cubic-bezier(0.25, 0.46, 0.45, 0.94)'
                });
                
                setTimeout(() => {
                    confetti.remove();
                }, duration * 1000);
            }
        }
    </script>
